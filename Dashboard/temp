@st.cache_data
def load_global_profiles():
    data = []
    with open("global_sender_profiles.jsonl", "r", encoding="utf-8") as f:
        for line in f:
            if line.strip():
                obj = json.loads(line)
                # Flatten variables for cleaner analysis operations
                flat = {
                    "sender_id": obj["sender_id"],
                    "risk_score": obj["overall_bert_profile"]["risk-score"],
                    "grooming": obj["overall_bert_profile"]["grooming"],
                    "bullying": obj["overall_bert_profile"]["bullying"],
                    "toxicity": obj["overall_bert_profile"]["toxicity"],
                    "sextortion": obj["overall_bert_profile"]["sextortion"],
                    "behavioral_summary": obj["global_llm_supervisor_analysis"]["global_behavioral_summary"]
                }
                data.append(flat)
    return pd.DataFrame(data)

@st.cache_data
def load_one_to_one_feed():
    data = []
    with open("oneToOne_conversations_dashboard_feed.jsonl", "r", encoding="utf-8") as f:
        for line in f:
            if line.strip():
                data.append(json.loads(line))
    return data

@st.cache_data
def load_raw_comments():
    data = []
    with open("comments_raw.jsonl", "r", encoding="utf-8") as f:
        for line in f:
            if line.strip():
                obj = json.loads(line)
                flat = {
                    "comment_id": obj["comment_id"],
                    "text": obj["text"],
                    "timestamp": obj["timestamp"],
                    "sender_id": obj["sender"]["user_id"],
                    "username": obj["sender"]["username"],
                    "receiver_id": obj["receiver"]["user_id"],
                    "is_parent_managed": obj["receiver"]["is_parent_managed"],
                    "report_count": obj["report_count"]
                }
                data.append(flat)
    return pd.DataFrame(data)

