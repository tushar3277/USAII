@st.cache_data
def load_global_profiles():
    data = []
    try:
        with open("global_sender_profiles.jsonl", "r", encoding="utf-8") as f:
            for line_idx, line in enumerate(f, 1):
                if line.strip():
                    try:
                        obj = json.loads(line)
                        flat = {
                            "sender_id": obj["overall_bert_profile"]["sender_id"] if "sender_id" in obj["overall_bert_profile"] else obj.get("sender_id", "unknown"),
                            "risk_score": obj["overall_bert_profile"]["risk-score"],
                            "grooming": obj["overall_bert_profile"]["grooming"],
                            "bullying": obj["overall_bert_profile"]["bullying"],
                            "toxicity": obj["overall_bert_profile"]["toxicity"],
                            "sextortion": obj["overall_bert_profile"].get("sextortion", 0.0),
                            "behavioral_summary": obj["global_llm_supervisor_analysis"]["global_behavioral_summary"]
                        }
                        data.append(flat)
                    except json.JSONDecodeError as je:
                        st.sidebar.warning(f"⚠️ Skipped malformed JSON row in global_sender_profiles.jsonl at line {line_idx}. Error: {je}")
    except FileNotFoundError:
        return pd.DataFrame(columns=["sender_id", "risk_score", "grooming", "bullying", "toxicity", "sextortion", "behavioral_summary"])
    return pd.DataFrame(data)

@st.cache_data
def load_one_to_one_feed():
    data = []
    try:
        with open("oneToOne_conversations_dashboard_feed.jsonl", "r", encoding="utf-8") as f:
            for line_idx, line in enumerate(f, 1):
                if line.strip():
                    try:
                        data.append(json.loads(line))
                    except json.JSONDecodeError as je:
                        st.sidebar.warning(f"⚠️ Skipped malformed JSON row in conversations feed at line {line_idx}. Error: {je}")
    except FileNotFoundError:
        return []
    return data

@st.cache_data
def load_raw_comments():
    data = []
    try:
        with open("comments_raw.jsonl", "r", encoding="utf-8") as f:
            for line_idx, line in enumerate(f, 1):
                if line.strip():
                    try:
                        obj = json.loads(line)
                        flat = {
                            "comment_id": obj["comment_id"],
                            "text": obj["text"],
                            "timestamp": obj["timestamp"],
                            "sender_id": obj["sender"]["user_id"],
                            "username": obj["sender"]["username"],
                            "receiver_id": obj["receiver"]["user_id"],
                            "is_parent_managed": obj["receiver"]["is_parent_managed"],
                            "report_count": obj["report_count"]
                        }
                        data.append(flat)
                    except json.JSONDecodeError as je:
                        st.sidebar.warning(f"⚠️ Skipped malformed JSON row in comments_raw.jsonl at line {line_idx}. Error: {je}")
    except FileNotFoundError:
        return pd.DataFrame(columns=["comment_id", "text", "timestamp", "sender_id", "username", "receiver_id", "is_parent_managed", "report_count"])
    return pd.DataFrame(data)

