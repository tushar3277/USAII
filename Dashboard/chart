# Helper function to find a key recursively anywhere within JSON structures
def find_key_recursive(d, key_name):
    if isinstance(d, dict):
        if key_name in d:
            return d[key_name]
        for v in d.values():
            res = find_key_recursive(v, key_name)
            if res:
                return res
    elif isinstance(d, list):
        for item in d:
            res = find_key_recursive(item, key_name)
            if res:
                return res
    return ""

